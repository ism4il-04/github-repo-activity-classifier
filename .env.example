# ==========================================
# Configuration de l'Interface (Streamlit)
# ==========================================

# Token de l'API GitHub pour contourner la limite de requêtes non authentifiées
# Créez un token sur https://github.com/settings/tokens (accès public repo uniquement)
GITHUB_TOKEN=ghp_votre_token_secret_ici

# URL de l'API Backend (FastAPI)
# Local: http://localhost:8000
# Docker: http://api:8000
API_URL=http://localhost:8000

# Utiliser l'API fictive pour le développement de l'UI (true/false)
USE_MOCK_API=false

# Port pour Streamlit (défaut: 8500)
PORT=8500


# ==========================================
# Configuration de l'API Backend (FastAPI)
# ==========================================

# Chemins vers les artefacts du modèle (chemins locaux)
MODEL_PATH=models/final_model.joblib
METADATA_PATH=models/final_model_metadata.json

# Niveau de log (debug, info, warning, error)
LOG_LEVEL=info
